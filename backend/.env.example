# Copy to .env and fill in as needed. All values have safe local defaults.

ENVIRONMENT=development

# Local default is SQLite (no setup). For Postgres:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/evalforge
DATABASE_URL=sqlite:///./evalforge.db

# Generate a strong value in production, e.g.: openssl rand -hex 32
SECRET_KEY=change-me-in-production-please

# Leave empty to run background jobs synchronously (no Redis needed).
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# Optional. If unset, a deterministic mock LLM is used (no cost, no network).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
